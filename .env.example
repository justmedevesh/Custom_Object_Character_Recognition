# ==========================================================
# Lab Report OCR — Optional environment overrides
# ----------------------------------------------------------
# Copy this file to ".env" and uncomment any value you want to
# override from config.yaml. Environment variables win over YAML.
# Only the scalar settings below are honoured as overrides.
# ==========================================================

# Path to the YOLO weights.
# LABOCR_MODEL_PATH=models/best.pt

# Default OCR engine: "Tesseract" | "EasyOCR" | "Auto (Tesseract → EasyOCR)"
# LABOCR_OCR_ENGINE=Auto (Tesseract → EasyOCR)

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
# LABOCR_LOG_LEVEL=INFO

# Hours before temp files are auto-cleaned on startup.
# LABOCR_TEMP_MAX_AGE_HOURS=24
